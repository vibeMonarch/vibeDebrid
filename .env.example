# =============================================================================
# vibeDebrid Docker Configuration
# Copy to .env and fill in your values: cp .env.example .env
# =============================================================================

# --- Required API Keys ---
RD_API_KEY=your_real_debrid_api_key
TMDB_API_KEY=your_tmdb_api_key

# --- Host Paths (must exist on your host) ---
# Quote paths that contain spaces.
ZURG_MOUNT_HOST_PATH=/opt/homeserver/Zurg/mnt
LIBRARY_MOVIES=/opt/homeserver/mnt/Movies
LIBRARY_SHOWS="/opt/homeserver/mnt/TV Shows"

# --- Timezone ---
TZ=UTC

# --- User/Group IDs (match your host user: run `id` to check) ---
PUID=1000
PGID=1000

# --- Ports ---
VIBE_PORT=5100
ZILEAN_PORT=8182

# --- Zilean Database (only needed with --profile stack) ---
POSTGRES_USER=zilean
POSTGRES_PASSWORD=zilean
POSTGRES_DB=zilean

# --- Media Servers (running on host, not in Docker) ---
# Defaults to host.docker.internal which resolves to your host machine.
# Change only if Plex/Jellyfin runs on a different machine or non-standard port.
# PLEX_URL=http://host.docker.internal:32400
# JELLYFIN_URL=http://host.docker.internal:8096

# --- Advanced ---
# ZILEAN_URL=http://zilean:8182         # Override if Zilean runs elsewhere
# ZILEAN_MIN_SCORE=0.85                 # Zilean minimum match score
# VIBE_IMAGE=vibemonarch/vibedebrid:latest  # Override image for local builds
