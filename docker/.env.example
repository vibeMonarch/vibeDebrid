# vibeDebrid Docker Environment
# Copy to .env in the project root and configure.

# User/Group IDs (match your host user for file permissions)
PUID=1000
PGID=1000

# Timezone
TZ=UTC

# Host path where rclone mounts Zurg (identity-mounted into containers)
ZURG_MOUNT_HOST_PATH=/opt/homeserver/Zurg/mnt

# Library directories for symlinks (identity-mounted, must be writable)
LIBRARY_MOVIES=/opt/homeserver/mnt/Movies
LIBRARY_SHOWS=/opt/homeserver/mnt/TV Shows

# Exposed ports
VIBE_PORT=5100
ZILEAN_PORT=8182

# Zilean PostgreSQL credentials
POSTGRES_USER=zilean
POSTGRES_PASSWORD=zilean
POSTGRES_DB=zilean

# Zilean configuration
ZILEAN_MIN_SCORE=0.85
